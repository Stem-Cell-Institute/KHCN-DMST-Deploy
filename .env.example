# =============================================================================
# SCI-ACE / KHCN-DMST — mẫu biến môi trường
# =============================================================================

# --- Ứng dụng & bảo mật ---
# JWT_SECRET: BẮT BUỘC (không có hoặc chỉ khoảng trắng → server thoát). Không dùng giá trị mẫu trên production.
# NODE_ENV=production: helmet bật Strict-Transport-Security (chỉ hợp lệ khi client truy cập qua HTTPS).
NODE_ENV=development
PORT=3000
JWT_SECRET=thay-bang-chuoi-ngau-nhien-dai-32-ky-tu-tro-len
BASE_URL=http://localhost:3000

# CORS: không dùng *. Chỉ origin trong whitelist mới được phản hồi Access-Control-Allow-Origin.
# Luôn gộp BASE_URL (đã chuẩn hoá) vào whitelist. Thêm domain khác (SPA tách subdomain, v.v.):
# CORS_ORIGINS=https://khcn.example.com,https://portal.example.com
# Production (NODE_ENV=production): phải có ít nhất một origin hợp lệ từ BASE_URL hoặc CORS_ORIGINS.
# CORS_ORIGINS=

# Múi giờ (mặc định trong code: Asia/Ho_Chi_Minh nếu không set)
# TZ=Asia/Ho_Chi_Minh

# --- Lắng nghe (Docker / reverse proxy) ---
# BIND_HOST=0.0.0.0
# TRUST_PROXY=1

# --- Body JSON (application/json) — không áp dụng multipart/multer ---
# BODY_JSON_LIMIT=12mb

# --- Giới hạn tốc độ API (express-rate-limit, toàn bộ /api/*) ---
# Gắn sớm trong stack — trước express.json — hạn chế flood body JSON.
# API_RATE_LIMIT_WINDOW_MS=900000
# API_RATE_LIMIT_MAX=400

# --- Dữ liệu trên đĩa (khuyến nghị production: volume riêng) ---
# Không set APP_DATA_DIR → DB và uploads nằm cạnh thư mục code (data/, uploads/).
# APP_DATA_DIR=/var/lib/sci-stims

# Tuỳ chọn: tách riêng file DB hoặc thư mục upload (ghi đè quy tắc mặc định)
# SQLITE_PATH=/var/lib/sci-stims/sci-ace.db
# SQLITE_DATA_DIR=/var/lib/sci-stims
# SQLITE_FILENAME=sci-ace.db
# UPLOADS_DIR=/var/lib/sci-stims/uploads
# UPLOADS_CAP_VIEN_DIR=/var/lib/sci-stims/uploads-cap-vien

# --- Cơ sở dữ liệu ---
# Mặc định: SQLite (đường dẫn file qua APP_DATA_DIR / data/ — xem lib/appPaths.js).
# Turso / LibSQL (bỏ comment và điền khi dùng cloud DB):
# DATABASE_URL=libsql://ten-db.turso.io
# DATABASE_AUTH_TOKEN=
# TURSO_MODE=local
# TURSO_LOCAL_HOST=127.0.0.1
# TURSO_PORT=8080

# --- SMTP (email thông báo; không set thì app vẫn chạy nhưng không gửi mail) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM: email gửi đi HOẶC chỉ tên hiển thị (không có @) — khi đó dùng chung địa chỉ SMTP_USER.
# Có khoảng trắng trong tên: dùng ngoặc kép, ví dụ SMTP_FROM="STIMS SCI"
# SMTP_FROM=noreply@example.com
# SMTP_FROM_NAME=Hệ thống STIMS SCI
# NOTIFICATION_EMAILS=a@vi.edu.vn,b@vi.edu.vn

# --- Gỡ lỗi ---
# DEBUG=
