# =============================================
# CẤU HÌNH DATABASE
# =============================================
# Chế độ SQLite (mặc định - cho local development)
# DATABASE_URL sẽ tự động dùng file SQLite local
DATABASE_URL=file:./data/sci-ace.db
SQLITE_FILENAME=sci-ace.db

# =============================================
# CHẾ ĐỘ TURSO LOCAL DAEMON (Khuyến nghị cho Production)
# =============================================
# 1. Cài Turso CLI: https://turso.tech/install
# 2. Chạy local daemon: turso dev --port 8080
# 3. Đặt DATABASE_URL (từ lệnh trên), đặt TURSO_MODE=turso-local
# 4. Chạy migration: npm run migrate:turso
# 5. Khởi động app: npm start
#
# DATABASE_URL=turso://localhost:8080/sci-ace
# TURSO_MODE=turso-local
# TURSO_LOCAL_HOST=127.0.0.1
# TURSO_LOCAL_PORT=8080

# =============================================
# CHẾ ĐỘ TURSO REMOTE (Cần refactor async - chưa khuyến nghị)
# =============================================
# DATABASE_URL=libsql://sci-ace.turso.io
# DATABASE_AUTH_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# TURSO_MODE=turso-remote

# =============================================
# CẤU HÌNH SERVER
# =============================================
PORT=3000
BASE_URL=http://localhost:3000
# IANA timezone — Vietnam ICT (UTC+7), same civil time Google uses for VN. Set before first DB use if overriding.
# TZ=Asia/Ho_Chi_Minh

# =============================================
# CẤU HÌNH JWT
# =============================================
JWT_SECRET=sci-ace-secret-change-in-production

# =============================================
# CẤU HÌNH EMAIL (SMTP)
# =============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
# Email gửi đi (thường trùng SMTP_USER hoặc alias @ tổ chức)
SMTP_FROM=hethongquanlykhcn_dmst@sci.edu.vn
# Tên hiển thị trong hộp thư người nhận (mặc định trong code nếu bỏ trống)
SMTP_FROM_NAME=Hệ thống quản lí KHCN&ĐMST SCI

# =============================================
# GỠ LỖI (tùy chọn)
# =============================================
# DEBUG=true

# =============================================
# CLI quét ORCID (npm run orcid:harvest) — tài khoản admin
# =============================================
# ORCID_CLI_EMAIL=admin@sci.edu.vn
# ORCID_CLI_PASSWORD=your-password