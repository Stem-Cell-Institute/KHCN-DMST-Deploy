# ── SCI-KHCN Publications Backend — Environment Variables ──────────────────────
# Sao chép file này thành .env và điền giá trị thực

# Môi trường
NODE_ENV=development          # development | production

# Server
PORT=3001                     # port backend lắng nghe

# Frontend origin (CORS)
FRONTEND_ORIGIN=http://localhost:3000   # prod: https://khcn-dmst.sci.edu.vn

# Database
# - Dev:  dùng SQLite, không cần DATABASE_URL
# - Prod: Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# ── API bên ngoài ──────────────────────────────────────────────────────────────

# Crossref Polite Pool — MIỄN PHÍ, không cần đăng ký
# Điền email thực để được ưu tiên rate limit cao hơn (polite pool)
CROSSREF_POLITE_EMAIL=sinhnguyen@sci.edu.vn

# Scopus API Key — TUỲ CHỌN
# Xin tại: https://dev.elsevier.com (cần tài khoản institutional của ĐHKTN/ĐHQG)
# Nếu có: tự động enrich IF, CiteScore, SJR, EID từ Scopus
# Nếu không có: admin nhập thủ công quartile và IF
SCOPUS_API_KEY=

# Tuỳ gói institutional Elsevier — khi API yêu cầu thêm insttoken
# SCOPUS_INST_TOKEN=

 # Web of Science API Key — TUỲ CHỌN
# Xin tại: https://developer.clarivate.com
WOS_API_KEY=

# ── Lưu ý về API miễn phí ─────────────────────────────────────────────────────
# ORCID Public API v3.0:   MIỄN PHÍ, không cần key  → pub.orcid.org/v3.0/
# Crossref Metadata API:   MIỄN PHÍ, không cần key  → api.crossref.org/works/
# PubMed E-utilities:      MIỄN PHÍ, không cần key  → eutils.ncbi.nlm.nih.gov/
# Unpaywall API:           MIỄN PHÍ, chỉ cần email  → api.unpaywall.org/v2/
# Scopus Abstract API:     CẦN KEY institutional     → api.elsevier.com/
# WoS Starter API:         CẦN KEY (5000 req/mon)   → api.clarivate.com/
